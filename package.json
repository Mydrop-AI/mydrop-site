{
  "name": "mydrop-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "validate:blog": "node scripts/validate-blog-posts.cjs",
    "prebuild": "npm run validate:blog && node scripts/generate-sitemap.cjs",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/react-snap.cjs",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "reactSnap": {
    "source": "dist",
    "inlineCss": false,
    "skipThirdPartyRequests": true,
    "concurrency": 1,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "puppeteerExecutablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
  },
  "dependencies": {
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jquery": "^3.7.1",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "@types/jquery": "^3.5.33",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
